rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function ownsUserDoc(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if ownsUserDoc(userId);

      match /{document=**} {
        allow read, write: if ownsUserDoc(userId);
      }
    }
  }
}
